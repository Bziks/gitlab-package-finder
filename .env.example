# GitLab API credentials
GITLAB_TOKEN=your-gitlab-personal-access-token
GITLAB_BASE_URL=https://gitlab.com/api/v4/

# Database
DB_HOST=127.0.0.1:3308
DB_USER=user
DB_PASS=pass
DB_NAME=gitlab_package_finder
# DB_MIGRATIONS_PATH=/app/migrations

# Redis
REDIS_HOSTS=localhost:6381

# Logging (optional - defaults shown)
# LOGGING_LEVEL=info

# Tracing (optional - defaults shown)
# TRACING_ENABLED=false
# TRACING_SAMPLE_RATE=0.0

# API server (optional - defaults shown)
# HTTP_PORT=58080

# Projects sync interval (optional - default: 1h)
# PROJECTS_SYNC_INTERVAL=1h

# Number of search processing worker replicas (optional - default: 1)
# WORKER_REPLICAS=1
